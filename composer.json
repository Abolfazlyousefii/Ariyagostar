{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.2.0 <8.4.0",
        "alexusmai/laravel-file-manager": "3.3.1",
        "barryvdh/laravel-debugbar": "3.16.0",
        "cviebrock/eloquent-sluggable": "10.0.0",
        "doctrine/dbal": "3.10.1",
        "fruitcake/php-cors": "1.3.0",
        "guzzlehttp/guzzle": "7.9.3",
        "illuminate/config": "10.48.29",
        "illuminate/support": "10.48.29",
        "intervention/image": "3.11.4",
        "jenssegers/agent": "2.6.4",
        "kavenegar/laravel": "1.3.8",
        "laravel-notification-channels/webpush": "9.0.0",
        "laravel/framework": "10.48.29",
        "laravel/sanctum": "3.3.3",
        "laravel/tinker": "2.10.1",
        "maatwebsite/excel": "3.1.66",
        "madnest/madzipper": "1.4.0",
        "melipayamak/laravel": "1.0.0",
        "mews/captcha": "3.4.6",
        "milon/barcode": "10.0.1",
        "morilog/jalali": "3.4.2",
        "myclabs/php-enum": "^1.8",
        "php-flasher/flasher-laravel": "1.15.14",
        "php-flasher/flasher-toastr-laravel": "1.15.14",
        "predis/predis": "1.1.10",
        "psr/log": "3.0.2",
        "pusher/pusher-php-server": "7.2.7",
        "rachidlaasri/laravel-installer": "4.1.0",
        "rap2hpoutre/laravel-log-viewer": "2.5.0",
        "spatie/laravel-backup": "8.8.2",
        "spatie/laravel-sitemap": "7.3.4",
        "yoeunes/toastr": "2.3.5"
    },
    "require-dev": {
        "spatie/laravel-ignition": "2.9.1",
        "fakerphp/faker": "1.24.1",
        "laravel/breeze": "1.29.1",
        "laravel/sail": "1.44.0",
        "mockery/mockery": "1.6.12",
        "nunomaduro/collision": "7.12.0",
        "phpunit/phpunit": "10.5.52"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Shetabit\\Payment\\": "packages/shetabit/payment/src/",
            "Shetabit\\Multipay\\": "packages/shetabit/multipay/src/",
            "Codedge\\Updater\\": "packages/codedge/laravel-selfupdater/src/",
            "Themes\\": "themes/"
        },
        "files": [
            "bootstrap/helpers.php",
            "packages/codedge/laravel-selfupdater/src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
